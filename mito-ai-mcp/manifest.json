{
  "manifest_version": "0.4",
  "name": "mito-ai",
  "display_name": "Mito AI",
  "version": "0.1.0",
  "description": "Use Mito AI for spreadsheet-style data analysis and Jupyter notebook workflows.",
  "author": {
    "name": "Saga Inc.",
    "email": "founders@sagacollab.com",
    "url": "https://trymito.io"
  },
  "homepage": "https://trymito.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/mito-ds/mito"
  },
  "server": {
    "type": "python",
    "entry_point": "mito_ai_mcp/server.py",
    "mcp_config": {
      "command": "uvx",
      "args": [
        "mito-ai-mcp"
      ],
      "env": {}
    }
  },
  "tools": [
    {
      "name": "run_data_analyst",
      "description": "Run one-shot Mito AI analysis for Excel/CSV workflows, EDA, and Jupyter notebook edits."
    }
  ],
  "compatibility": {
    "claude_desktop": ">=0.10.0",
    "platforms": [
      "darwin",
      "win32"
    ]
  },
  "keywords": [
    "data-analysis",
    "spreadsheets",
    "jupyter",
    "excel",
    "csv"
  ],
  "license": "AGPL-3.0-only"
}