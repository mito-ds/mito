{
    "compilerOptions": {
        "module": "ES2020",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src"
    ]
}